{
  "name": "realtalk-english",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "echo 'Mixed-language monorepo: start each sub-project individually'",
    "dev:admin": "pnpm --filter admin-web run dev",
    "dev:mobile": "pnpm --filter mobile-app run dev",
    "dev:mock": "pnpm --filter mock-server run start",
    "dev:backend": "cd apps/api-backend && uvicorn app.main:app --reload --port 8000",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "mock": "pnpm --filter mock-server run start",
    "e2e": "pnpm --filter e2e run test"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
