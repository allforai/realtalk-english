# === Common ===
NODE_ENV=development

# === Backend (FastAPI) ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/realtalk
JWT_SECRET=change-me-in-production
API_PORT=8000
OPENAI_API_KEY=sk-your-key-here
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# === Mock Server ===
MOCK_PORT=4000

# === Admin Web (Next.js) ===
NEXT_PUBLIC_API_BASE=http://localhost:4000
# Production: NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# === Mobile App (Expo) ===
EXPO_PUBLIC_API_URL=http://localhost:4000
# Production: EXPO_PUBLIC_API_URL=https://api.realtalk.app/api/v1
